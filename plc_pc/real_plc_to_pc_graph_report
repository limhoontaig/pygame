            ["선간전압", "T-R", get_stat("MAX", "KEP_V_T_R"), get_stat("MIN", "KEP_V_T_R"), get_stat("MAX", "Tr1_V_T_R"), get_stat("MIN", "Tr1_V_T_R"), get_stat("MAX", "Tr2_V_T_R"), get_stat("MIN", "Tr2_V_T_R"), get_stat("MAX", "Tr3_V_T_R"), get_stat("MIN", "Tr3_V_T_R")],
            ["전류", "R", get_stat("MAX", "KEP_A_R"), get_stat("MIN", "KEP_A_R"), get_stat("MAX", "Tr1_A_R"), get_stat("MIN", "Tr1_A_R"), get_stat("MAX", "Tr2_A_R"), get_stat("MIN", "Tr2_A_R"), get_stat("MAX", "Tr3_A_R"), get_stat("MIN", "Tr3_A_R")],
            ["전류", "S", get_stat("MAX", "KEP_A_S"), get_stat("MIN", "KEP_A_S"), get_stat("MAX", "Tr1_A_S"), get_stat("MIN", "Tr1_A_S"), get_stat("MAX", "Tr2_A_S"), get_stat("MIN", "Tr2_A_S"), get_stat("MAX", "Tr3_A_S"), get_stat("MIN", "Tr3_A_S")],
            ["전류", "T", get_stat("MAX", "KEP_A_T"), get_stat("MIN", "KEP_A_T"), get_stat("MAX", "Tr1_A_T"), get_stat("MIN", "Tr1_A_T"), get_stat("MAX", "Tr2_A_T"), get_stat("MIN", "Tr2_A_T"), get_stat("MAX", "Tr3_A_T"), get_stat("MIN", "Tr3_A_T")],
            ["역률/주파수", "Hz", get_stat("MAX", "KEP_frequency"), get_stat("MIN", "KEP_frequency"), "-", "-", "-", "-", "-", "-"],
            ["부하전력", "kW", get_stat("MAX", "KEP_P_kW"), get_stat("MIN", "KEP_P_kW"), get_stat("MAX", "Tr1_P_kW"), get_stat("MIN", "Tr1_P_kW"), get_stat("MAX", "Tr2_P_kW"), get_stat("MIN", "Tr2_P_kW"), get_stat("MAX", "Tr3_P_kW"), get_stat("MIN", "Tr3_P_kW")],
            ["설비온도", "°C", "-", "-", get_stat("MAX", "Tr1_Temp"), get_stat("MIN", "Tr1_Temp"), get_stat("MAX", "Tr2_Temp"), get_stat("MIN", "Tr2_Temp"), get_stat("MAX", "Tr3_Temp"), get_stat("MIN", "Tr3_Temp")]
        ]
        
        for row in stat_rows:
            ws_summary.append(row)
            
        # 하단 적산 유효전력량 현황 레이아웃 추가 연산
        ws_summary.append([])
        ws_summary.append(["● 전력량계 전력 적산 현황 요약"])
        
        # 금일 지침 및 전일 지침 값 추출 계산
        today_mwh = get_stat("MAX", "KEP_P_mWh")
        # 전일 날짜 연산 계산
        prev_date = (datetime.strptime(selected_date, "%Y-%m-%d") - timedelta(days=1)).strftime("%Y-%m-%d")
        c.execute('SELECT MAX("KEP_P_mWh") FROM raw_data WHERE log_date = ?', (prev_date,))
        prev_mwh_res = c.fetchone()[0]
        prev_mwh = round(prev_mwh_res, 1) if prev_mwh_res is not None else "-"
        
        if today_mwh != "-" and prev_mwh != "-":
            diff_mwh = round(today_mwh - prev_mwh, 2)
        else:
            diff_mwh = "-"
            
        ws_summary.append(["구분", "금일 지침", "전일 지침", "지침 차이 사용량"])
        ws_summary.append(["한전 메인 유효전력량(mWh)", today_mwh, prev_mwh, diff_mwh])

