            c.execute(query_raw, (selected_date,))
            rows_raw = c.fetchall()
            self.display_table(self.raw_table, rows_raw)
            
            query_avg = f"SELECT log_date, log_time, {', '.join([f'\"{n}\"' for n in DATA_LABELS])} FROM hourly_avg WHERE log_date = ? ORDER BY log_time ASC"
            c.execute(query_avg, (selected_date,))
            rows_avg = c.fetchall()
            self.display_table(self.avg_table, rows_avg)
            
            query_ext = f"SELECT log_date, extreme_type, {', '.join([f'\"{n}\"' for n in DATA_LABELS])} FROM daily_extremes WHERE log_date = ? ORDER BY extreme_type DESC"
            c.execute(query_ext, (selected_date,))
            rows_ext = c.fetchall()
            self.display_table(self.extreme_table, rows_ext, is_extreme=True)
            
            conn.close()
        except Exception as e:
