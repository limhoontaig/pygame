            ["상전압", "R", get_stat("MAX", "KEP_V_R"), get_stat("MIN", "KEP_V_R"), get_stat("MAX", "Tr1_V_R"), get_stat("MIN", "Tr1_V_R"), get_stat("MAX", "Tr2_V_R"), get_stat("MIN", "Tr2_V_R"), get_stat("MAX", "Tr3_V_R"), get_stat("MIN", "Tr3_V_R")],
