            ["상전압", "T", get_stat("MAX", "KEP_V_T"), get_stat("MIN", "KEP_V_T"), get_stat("MAX", "Tr1_V_T"), get_stat("MIN", "Tr1_V_T"), get_stat("MAX", "Tr2_V_T"), get_stat("MIN", "Tr2_V_T"), get_stat("MAX", "Tr3_V_T"), get_stat("MIN", "Tr3_V_T")],
            ["선간전압", "R-S", get_stat("MAX", "KEP_V_R_S"), get_stat("MIN", "KEP_V_R_S"), get_stat("MAX", "Tr1_V_R_S"), get_stat("MIN", "Tr1_V_R_S"), get_stat("MAX", "Tr2_V_R_S"), get_stat("MIN", "Tr2_V_R_S"), get_stat("MAX", "Tr3_V_R_S"), get_stat("MIN", "Tr3_V_R_S")],
